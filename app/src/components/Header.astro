---
const pathname = Astro.url.pathname;
---

<header class="glass border-b border-white/5 sticky top-0 z-50">
  <nav class="max-w-6xl mx-auto px-6 h-16 flex items-center justify-between">
    <a href="/" class="flex items-center gap-2.5 group">
      <div class="w-8 h-8 rounded-lg bg-gradient-to-br from-accent to-cyan flex items-center justify-center shadow-lg shadow-accent/20 group-hover:shadow-accent/40 transition-shadow">
        <svg class="w-4 h-4 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z" />
        </svg>
      </div>
      <span class="font-bold text-lg text-white tracking-tight">A2A</span>
    </a>
    <div class="flex items-center gap-1">
      <a href="/dashboard" class:list={[
        "text-sm px-4 py-2 rounded-lg transition-all duration-200",
        pathname === '/dashboard'
          ? 'text-white bg-white/5'
          : 'text-navy-400 hover:text-white hover:bg-white/5'
      ]}>
        Dashboard
      </a>
      <a href="/leaderboard" class:list={[
        "text-sm px-4 py-2 rounded-lg transition-all duration-200",
        pathname === '/leaderboard'
          ? 'text-white bg-white/5'
          : 'text-navy-400 hover:text-white hover:bg-white/5'
      ]}>
        Leaderboard
      </a>
      <div class="w-px h-6 bg-white/10 mx-2"></div>
      <a href="/login" class="btn-shimmer text-sm text-white px-5 py-2 rounded-lg font-medium">
        Sign In
      </a>
    </div>
  </nav>
</header>
