---
interface Props {
  slug: string;
  number: string;
  title: string;
  exerciseCount: number;
  estimatedTime: string;
  cost: string;
  month: string;
  completedExercises?: number;
  quizPassed?: boolean;
  quizScore?: number;
  status?: 'not_started' | 'in_progress' | 'completed';
}

const {
  slug, number, title, exerciseCount, estimatedTime, cost, month,
  completedExercises = 0, quizPassed = false, quizScore, status = 'not_started'
} = Astro.props;

const progressPercent = Math.round((completedExercises / exerciseCount) * 100);

const moduleIcons: Record<string, string> = {
  '01': '\u{1F433}', '02': '\u2601\uFE0F', '03': '\u{1F3D7}\uFE0F',
  '04': '\u{1F4E6}', '05': '\u2699\uFE0F', '06': '\u{1F680}',
  '07': '\u{1F4CA}', '08': '\u{1F9E9}', '09': '\u{1F3AF}',
  '10': '\u{1F916}',
};
---

<a href={`/modules/${slug}`} class="block group glow-card rounded-2xl p-5">
  <div class="flex items-start justify-between mb-4">
    <div class="flex items-center gap-3">
      <div class="w-10 h-10 rounded-xl bg-white/5 border border-white/10 flex items-center justify-center text-lg group-hover:scale-110 group-hover:bg-accent/10 group-hover:border-accent/30 transition-all duration-300">
        {moduleIcons[number]}
      </div>
      <div>
        <span class="text-[10px] font-mono text-accent/50 uppercase tracking-wider block">{month}</span>
        <span class:list={[
          "flex items-center gap-1.5 text-[10px] font-medium mt-0.5",
          status === 'completed' ? 'text-success' : status === 'in_progress' ? 'text-warning' : 'text-navy-600'
        ]}>
          <span class:list={[
            "w-1.5 h-1.5 rounded-full",
            status === 'completed' ? 'bg-success' : status === 'in_progress' ? 'bg-warning animate-pulse' : 'bg-navy-700'
          ]}></span>
          {status === 'completed' ? 'Completed' : status === 'in_progress' ? 'In Progress' : 'Not Started'}
        </span>
      </div>
    </div>
  </div>

  <h3 class="text-white font-semibold mb-1.5 group-hover:text-accent transition-colors leading-snug">
    {title}
  </h3>

  <div class="flex items-center gap-2 text-xs text-navy-500 mb-5">
    <span class="bg-white/[0.03] px-2 py-0.5 rounded">{estimatedTime}</span>
    {cost !== 'Free' ? (
      <span class="bg-warning/10 text-warning px-2 py-0.5 rounded">{cost}</span>
    ) : (
      <span class="bg-success/10 text-success px-2 py-0.5 rounded">Free</span>
    )}
  </div>

  <!-- Progress bar -->
  <div class="mb-3">
    <div class="flex justify-between text-[11px] text-navy-500 mb-1.5">
      <span>Exercises</span>
      <span class="font-mono">{completedExercises}/{exerciseCount}</span>
    </div>
    <div class="h-1.5 bg-white/5 rounded-full overflow-hidden">
      <div
        class="h-full rounded-full transition-all duration-700 bg-gradient-to-r from-accent to-cyan"
        style={`width: ${progressPercent}%`}
      ></div>
    </div>
  </div>

  <!-- Quiz status -->
  <div class="flex items-center justify-between text-[11px] pt-3 border-t border-white/5">
    <span class="text-navy-500">Quiz</span>
    {quizPassed ? (
      <span class="text-success font-medium flex items-center gap-1">
        <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg>
        Passed {quizScore}%
      </span>
    ) : quizScore !== undefined ? (
      <span class="text-danger font-medium">Failed {quizScore}%</span>
    ) : (
      <span class="text-navy-600">Not attempted</span>
    )}
  </div>
</a>
