---
import Layout from '../layouts/Layout.astro';
import { MODULE_CONFIGS } from '../lib/modules';

const moduleIcons: Record<string, string> = {
  '01-docker': '\u{1F433}',
  '02-aws-foundations': '\u2601\uFE0F',
  '03-aws-sa-associate': '\u{1F3D7}\uFE0F',
  '04-terraform': '\u{1F4E6}',
  '05-kubernetes': '\u2699\uFE0F',
  '06-ci-cd-pipelines': '\u{1F680}',
  '07-monitoring-observability': '\u{1F4CA}',
  '08-system-design': '\u{1F9E9}',
  '09-interview-prep': '\u{1F3AF}',
  '10-ai-for-cloud-devops': '\u{1F916}',
};
---

<Layout title="Home">
  <!-- Hero -->
  <section class="relative overflow-hidden min-h-[90vh] flex items-center">
    <!-- Animated background -->
    <div class="absolute inset-0 grid-bg opacity-50"></div>
    <div class="orb w-[500px] h-[500px] bg-accent/20 -top-48 -right-24" style="animation-delay: 0s;"></div>
    <div class="orb w-[400px] h-[400px] bg-cyan/15 -bottom-32 -left-20" style="animation-delay: 2s;"></div>
    <div class="orb w-[300px] h-[300px] bg-purple/10 top-1/2 left-1/2" style="animation-delay: 4s;"></div>

    <div class="max-w-6xl mx-auto px-6 py-24 text-center relative z-10">
      <div class="inline-flex items-center gap-2 glass text-accent text-sm px-5 py-2 rounded-full mb-8 shadow-lg shadow-accent/5">
        <span class="w-2 h-2 rounded-full bg-success animate-pulse"></span>
        Free &amp; Open Source &mdash; 58 exercises &middot; 10 modules
      </div>

      <h1 class="text-5xl sm:text-7xl font-extrabold text-white mb-6 leading-[1.1] tracking-tight">
        From Automation<br/>
        to <span class="gradient-text">Architect</span>
      </h1>

      <p class="text-lg sm:text-xl text-navy-400 max-w-2xl mx-auto mb-12 leading-relaxed">
        A structured, hands-on learning path for automation engineers transitioning to
        <span class="text-navy-200">Solutions Architect</span>,
        <span class="text-navy-200">Platform Engineer</span>, or
        <span class="text-navy-200">DevOps</span> roles.
      </p>

      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a href="/dashboard" class="btn-shimmer text-white font-semibold px-10 py-4 rounded-xl text-lg">
          Start Learning &mdash; Free
        </a>
        <a href="https://github.com/stasfire/automation-to-architect" target="_blank" rel="noopener"
          class="group flex items-center gap-2 border border-white/10 text-navy-300 hover:text-white hover:border-white/25 hover:bg-white/5 px-8 py-4 rounded-xl transition-all text-lg">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
          View on GitHub
        </a>
      </div>

      <!-- Floating tech badges -->
      <div class="flex flex-wrap items-center justify-center gap-3 mt-16">
        {['Docker', 'AWS', 'Terraform', 'Kubernetes', 'CI/CD', 'System Design'].map(tech => (
          <span class="text-xs text-navy-500 bg-white/[0.03] border border-white/5 px-3 py-1.5 rounded-full">
            {tech}
          </span>
        ))}
      </div>
    </div>
  </section>

  <!-- Stats -->
  <section class="relative border-y border-white/5">
    <div class="absolute inset-0 bg-gradient-to-r from-accent/5 via-transparent to-cyan/5"></div>
    <div class="max-w-6xl mx-auto px-6 py-10 grid grid-cols-2 sm:grid-cols-4 gap-8 text-center relative">
      {[
        { value: '10', label: 'Modules', icon: '\u{1F4DA}' },
        { value: '58', label: 'Exercises', icon: '\u{1F4BB}' },
        { value: '~6mo', label: 'Timeline', icon: '\u23F1\uFE0F' },
        { value: '$263', label: 'Total Cost', icon: '\u{1F4B0}' },
      ].map(stat => (
        <div class="group">
          <div class="text-2xl mb-2">{stat.icon}</div>
          <div class="text-3xl font-bold text-white group-hover:text-accent transition-colors">{stat.value}</div>
          <div class="text-sm text-navy-500 mt-1">{stat.label}</div>
        </div>
      ))}
    </div>
  </section>

  <!-- Module Roadmap -->
  <section class="max-w-5xl mx-auto px-6 py-24">
    <div class="text-center mb-16">
      <span class="text-accent text-sm font-semibold tracking-widest uppercase">Curriculum</span>
      <h2 class="text-3xl sm:text-4xl font-bold text-white mt-3 mb-4">The Learning Path</h2>
      <p class="text-navy-400 max-w-xl mx-auto">
        10 modules. From containers to system design interviews. Each one builds on the last.
      </p>
    </div>

    <div class="relative">
      <!-- Glowing timeline line -->
      <div class="absolute left-7 top-4 bottom-4 w-0.5 timeline-line rounded-full hidden sm:block opacity-30"></div>

      <div class="space-y-4">
        {MODULE_CONFIGS.map((mod, i) => (
          <a href={`/modules/${mod.slug}`} class="flex items-start gap-5 group">
            <!-- Timeline node -->
            <div class="hidden sm:flex items-center justify-center w-14 h-14 rounded-2xl bg-navy-800/80 border border-white/10 text-2xl flex-shrink-0 z-10 group-hover:border-accent/50 group-hover:bg-accent/10 group-hover:shadow-lg group-hover:shadow-accent/10 transition-all duration-300">
              {moduleIcons[mod.slug]}
            </div>
            <!-- Card -->
            <div class="flex-1 glow-card rounded-xl p-5 group-hover:border-accent/30">
              <div class="flex items-start justify-between mb-2">
                <div>
                  <span class="text-xs font-mono text-accent/60 block mb-1">Module {mod.number}</span>
                  <h3 class="text-white font-semibold text-lg group-hover:text-accent transition-colors">{mod.title}</h3>
                </div>
                <div class="flex items-center gap-3 flex-shrink-0 ml-4">
                  <span class="text-xs text-navy-500 bg-white/[0.03] px-2.5 py-1 rounded-md">{mod.estimatedTime}</span>
                  {mod.cost !== 'Free' ? (
                    <span class="text-xs text-warning bg-warning/10 px-2.5 py-1 rounded-md">{mod.cost}</span>
                  ) : (
                    <span class="text-xs text-success bg-success/10 px-2.5 py-1 rounded-md">Free</span>
                  )}
                </div>
              </div>
              <div class="flex items-center gap-4 text-xs text-navy-500">
                <span>{mod.exerciseCount} exercises</span>
                <span class="text-navy-700">&middot;</span>
                <span>{mod.month}</span>
                <span class="ml-auto text-accent opacity-0 group-hover:opacity-100 transition-opacity">
                  Start learning &rarr;
                </span>
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Target Roles -->
  <section class="relative border-t border-white/5 overflow-hidden">
    <div class="orb w-[400px] h-[400px] bg-purple/10 -bottom-48 right-0"></div>
    <div class="max-w-6xl mx-auto px-6 py-24 relative">
      <div class="text-center mb-16">
        <span class="text-cyan text-sm font-semibold tracking-widest uppercase">Career Outcomes</span>
        <h2 class="text-3xl sm:text-4xl font-bold text-white mt-3 mb-4">Where This Takes You</h2>
        <p class="text-navy-400 max-w-xl mx-auto">
          Real roles with real salary ranges. This curriculum maps directly to job requirements.
        </p>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-5">
        {[
          { role: 'Integration Engineer', salary: '$90K\u2013$140K', gradient: 'from-blue-500/20 to-cyan/20', border: 'hover:border-cyan/40', shadow: 'hover:shadow-cyan/10' },
          { role: 'DevOps Engineer', salary: '$110K\u2013$160K', gradient: 'from-accent/20 to-purple/20', border: 'hover:border-accent/40', shadow: 'hover:shadow-accent/10' },
          { role: 'Platform Engineer', salary: '$120K\u2013$180K', gradient: 'from-purple/20 to-pink/20', border: 'hover:border-purple/40', shadow: 'hover:shadow-purple/10' },
          { role: 'Solutions Architect', salary: '$130K\u2013$200K+', gradient: 'from-success/20 to-cyan/20', border: 'hover:border-success/40', shadow: 'hover:shadow-success/10' },
        ].map(r => (
          <div class:list={["relative group rounded-2xl border border-white/10 p-6 text-center transition-all duration-300 hover:-translate-y-1 hover:shadow-lg", r.border, r.shadow]}>
            <div class:list={["absolute inset-0 rounded-2xl bg-gradient-to-br opacity-0 group-hover:opacity-100 transition-opacity -z-10", r.gradient]}></div>
            <h3 class="text-white font-semibold text-lg mb-2">{r.role}</h3>
            <p class="text-2xl font-bold gradient-text">{r.salary}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="relative overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-t from-accent/5 to-transparent"></div>
    <div class="max-w-6xl mx-auto px-6 py-24 text-center relative">
      <h2 class="text-3xl sm:text-4xl font-bold text-white mb-4">Ready to Level Up?</h2>
      <p class="text-navy-400 mb-10 max-w-md mx-auto text-lg">
        Start your transition from automation to architecture. It's free, open source, and built by engineers like you.
      </p>
      <a href="/dashboard" class="btn-shimmer inline-block text-white font-semibold px-10 py-4 rounded-xl text-lg">
        Start Learning
      </a>
    </div>
  </section>
</Layout>
