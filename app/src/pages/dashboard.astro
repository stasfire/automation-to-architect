---
import Layout from '../layouts/Layout.astro';
import ModuleCard from '../components/ModuleCard.astro';
import { MODULE_CONFIGS } from '../lib/modules';

const totalExercises = MODULE_CONFIGS.reduce((sum, m) => sum + m.exerciseCount, 0);
---

<Layout title="Dashboard">
  <!-- Gradient header banner -->
  <div class="relative overflow-hidden border-b border-white/5">
    <div class="absolute inset-0 bg-gradient-to-r from-accent/10 via-purple/5 to-cyan/10"></div>
    <div class="absolute inset-0 grid-bg opacity-30"></div>
    <div class="max-w-6xl mx-auto px-6 py-10 relative">
      <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-6">
        <div>
          <h1 class="text-3xl font-bold text-white mb-1">Learning Dashboard</h1>
          <p class="text-navy-400">Track your progress through all 10 modules</p>
        </div>
        <!-- Stats pills -->
        <div class="flex items-center gap-3">
          <div class="glass rounded-xl px-5 py-3 text-center min-w-[80px]">
            <div class="text-xl font-bold gradient-text">0%</div>
            <div class="text-[10px] text-navy-500 uppercase tracking-wider mt-0.5">Done</div>
          </div>
          <div class="glass rounded-xl px-5 py-3 text-center min-w-[80px]">
            <div class="text-xl font-bold text-white">0<span class="text-navy-500 text-sm">/{totalExercises}</span></div>
            <div class="text-[10px] text-navy-500 uppercase tracking-wider mt-0.5">Exercises</div>
          </div>
          <div class="glass rounded-xl px-5 py-3 text-center min-w-[80px]">
            <div class="text-xl font-bold text-white">0<span class="text-navy-500 text-sm">/10</span></div>
            <div class="text-[10px] text-navy-500 uppercase tracking-wider mt-0.5">Quizzes</div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="max-w-6xl mx-auto px-6 py-10">
    <!-- Module Grid -->
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
      {MODULE_CONFIGS.map(mod => (
        <ModuleCard
          slug={mod.slug}
          number={mod.number}
          title={mod.title}
          exerciseCount={mod.exerciseCount}
          estimatedTime={mod.estimatedTime}
          cost={mod.cost}
          month={mod.month}
        />
      ))}
    </div>

    <!-- Certifications -->
    <section class="mt-14">
      <div class="flex items-center gap-3 mb-6">
        <div class="w-8 h-8 rounded-lg bg-gradient-to-br from-warning to-orange-500 flex items-center justify-center text-sm">
          <svg class="w-4 h-4 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12c0 1.268-.63 2.39-1.593 3.068a3.745 3.745 0 01-1.043 3.296 3.745 3.745 0 01-3.296 1.043A3.745 3.745 0 0112 21c-1.268 0-2.39-.63-3.068-1.593a3.746 3.746 0 01-3.296-1.043 3.745 3.745 0 01-1.043-3.296A3.745 3.745 0 013 12c0-1.268.63-2.39 1.593-3.068a3.745 3.745 0 011.043-3.296 3.746 3.746 0 013.296-1.043A3.746 3.746 0 0112 3c1.268 0 2.39.63 3.068 1.593a3.746 3.746 0 013.296 1.043 3.746 3.746 0 011.043 3.296A3.745 3.745 0 0121 12z" />
          </svg>
        </div>
        <h2 class="text-xl font-bold text-white">Certification Tracker</h2>
      </div>
      <div class="grid sm:grid-cols-3 gap-5">
        {[
          { name: 'AWS Solutions Architect Associate', cost: '$150', when: 'Month 3', color: 'from-orange-500/20 to-amber-500/20', icon: '\u2601\uFE0F' },
          { name: 'HashiCorp Terraform Associate', cost: '$70', when: 'Month 4-5', color: 'from-purple/20 to-accent/20', icon: '\u{1F4E6}' },
          { name: 'CKAD (Stretch Goal)', cost: '$395', when: 'Month 7+', color: 'from-cyan/20 to-blue-500/20', icon: '\u2699\uFE0F' },
        ].map(cert => (
          <div class="glow-card rounded-xl p-5 group">
            <div class:list={["absolute inset-0 rounded-xl bg-gradient-to-br opacity-0 group-hover:opacity-100 transition-opacity -z-10", cert.color]}></div>
            <div class="text-2xl mb-3">{cert.icon}</div>
            <h3 class="text-white font-medium mb-2">{cert.name}</h3>
            <div class="flex items-center gap-3 text-xs text-navy-500 mb-4">
              <span>{cert.cost}</span>
              <span class="text-white/10">&middot;</span>
              <span>{cert.when}</span>
            </div>
            <div class="flex items-center gap-2 text-xs text-navy-600">
              <div class="w-3 h-3 rounded-full border border-navy-600"></div>
              Not yet passed
            </div>
          </div>
        ))}
      </div>
    </section>
  </div>
</Layout>
