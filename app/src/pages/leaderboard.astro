---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Leaderboard">
  <!-- Header -->
  <div class="relative overflow-hidden border-b border-white/5">
    <div class="absolute inset-0 bg-gradient-to-r from-warning/5 via-transparent to-accent/5"></div>
    <div class="max-w-4xl mx-auto px-6 py-8 relative">
      <div class="flex items-center gap-3 mb-2">
        <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-warning to-orange-500 flex items-center justify-center text-lg shadow-lg shadow-warning/20">
          <svg class="w-5 h-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M16.5 18.75h-9m9 0a3 3 0 013 3h-15a3 3 0 013-3m9 0v-3.375c0-.621-.503-1.125-1.125-1.125h-.871M7.5 18.75v-3.375c0-.621.504-1.125 1.125-1.125h.872m5.007 0H9.497m5.007 0a7.454 7.454 0 01-.982-3.172M9.497 14.25a7.454 7.454 0 00.981-3.172M5.25 4.236c-.982.143-1.954.317-2.916.52A6.003 6.003 0 007.73 9.728M5.25 4.236V4.5c0 2.108.966 3.99 2.48 5.228M5.25 4.236V2.721C7.456 2.41 9.71 2.25 12 2.25c2.291 0 4.545.16 6.75.47v1.516M18.75 4.236c.982.143 1.954.317 2.916.52A6.003 6.003 0 0016.27 9.728M18.75 4.236V4.5c0 2.108-.966 3.99-2.48 5.228m0 0a6.023 6.023 0 01-2.27.852m4.75-6.316V2.721" />
          </svg>
        </div>
        <div>
          <h1 class="text-2xl font-bold text-white">Leaderboard</h1>
          <p class="text-sm text-navy-400">Top learners ranked by overall progress</p>
        </div>
      </div>
    </div>
  </div>

  <div class="max-w-4xl mx-auto px-6 py-10">
    <!-- Table header -->
    <div class="glow-card rounded-2xl overflow-hidden">
      <div class="grid grid-cols-6 gap-4 px-6 py-3 border-b border-white/5 text-[10px] text-navy-500 uppercase tracking-widest font-medium">
        <div>Rank</div>
        <div class="col-span-2">Learner</div>
        <div class="text-center">Modules</div>
        <div class="text-center">Quizzes</div>
        <div class="text-right">Progress</div>
      </div>

      <!-- Empty state -->
      <div class="px-6 py-16 text-center">
        <div class="w-16 h-16 rounded-2xl bg-white/5 border border-white/10 flex items-center justify-center text-3xl mx-auto mb-4">
          <svg class="w-8 h-8 text-navy-700" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M18 18.72a9.094 9.094 0 003.741-.479 3 3 0 00-4.682-2.72m.94 3.198l.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0112 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 016 18.719m12 0a5.971 5.971 0 00-.941-3.197m0 0A5.995 5.995 0 0012 12.75a5.995 5.995 0 00-5.058 2.772m0 0a3 3 0 00-4.681 2.72 8.986 8.986 0 003.74.477m.94-3.197a5.971 5.971 0 00-.94 3.197M15 6.75a3 3 0 11-6 0 3 3 0 016 0zm6 3a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0zm-13.5 0a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0z" />
          </svg>
        </div>
        <p class="text-navy-500 font-medium mb-1">No learners yet</p>
        <p class="text-sm text-navy-600">Be the first to sign up and start climbing!</p>
        <a href="/dashboard" class="inline-block mt-5 btn-shimmer text-white text-sm font-medium px-6 py-2.5 rounded-lg">
          Start Learning
        </a>
      </div>
    </div>
  </div>
</Layout>
