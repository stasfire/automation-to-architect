---
import Layout from '../../layouts/Layout.astro';
import Quiz from '../../components/Quiz.tsx';
import { MODULE_CONFIGS, getModuleConfig, getQuizQuestions } from '../../lib/modules';

const { slug } = Astro.params;
const config = getModuleConfig(slug!);

if (!config) {
  return Astro.redirect('/dashboard');
}

const questions = getQuizQuestions(slug!);
---

<Layout title={`Quiz: ${config.title}`}>
  <!-- Quiz header -->
  <div class="relative overflow-hidden border-b border-white/5">
    <div class="absolute inset-0 bg-gradient-to-r from-purple/10 via-transparent to-accent/10"></div>
    <div class="max-w-4xl mx-auto px-6 py-8 relative">
      <nav class="flex items-center gap-2 text-sm text-navy-500 mb-5">
        <a href="/dashboard" class="hover:text-navy-300 transition-colors">Dashboard</a>
        <svg class="w-3 h-3 text-navy-700" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
        <a href={`/modules/${slug}`} class="hover:text-navy-300 transition-colors">Module {config.number}</a>
        <svg class="w-3 h-3 text-navy-700" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
        <span class="text-navy-300">Quiz</span>
      </nav>

      <div class="flex items-center gap-4">
        <div class="w-12 h-12 rounded-2xl bg-gradient-to-br from-purple to-accent flex items-center justify-center shadow-lg shadow-accent/20">
          <svg class="w-6 h-6 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9.879 7.519c1.171-1.025 3.071-1.025 4.242 0 1.172 1.025 1.172 2.687 0 3.712-.203.179-.43.326-.67.442-.745.361-1.45.999-1.45 1.827v.75M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-9 5.25h.008v.008H12v-.008z" />
          </svg>
        </div>
        <div>
          <h1 class="text-2xl font-bold text-white">Quiz: {config.title}</h1>
          <div class="flex items-center gap-3 mt-1">
            <span class="text-xs text-navy-400">{questions.length} questions</span>
            <span class="text-white/10">&middot;</span>
            <span class="text-xs text-success">80% to pass</span>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="max-w-4xl mx-auto px-6 py-10">
    <Quiz client:load questions={questions} moduleTitle={config.title} moduleSlug={slug!} />
  </div>
</Layout>
